{
  "info": {
    "name": "AutoParts Pro Collection",
    "description": "API testing collection for AutoParts Pro (Workshop 3)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1. GET All Products",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/products",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "products"
          ]
        }
      },
      "response": []
    },
    {
      "name": "2. POST Register User",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status Code should be 201\", function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "",
              "pm.test(\"Response must be in JSON format\", function () {",
              "    pm.response.to.be.json;",
              "});",
              "",
              "pm.test(\"Check if JWT token exists\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.token).to.not.be.undefined;",
              "    // Automatically save the token to environment variables if it exists",
              "    if (jsonData.token) {",
              "        pm.environment.set(\"token\", jsonData.token);",
              "    }",
              "});",
              "",
              "pm.test(\"Check success flag\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.success).to.eql(true);",
              "});",
              "",
              "pm.test(\"Response time should be less than 2000ms\", function () {",
              "    pm.expect(pm.response.responseTime).to.be.below(2000);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Somchai Test\",\n  \"email\": \"somchai_{{$timestamp}}@example.com\",\n  \"password\": \"password123\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{baseUrl}}/auth/register",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "auth",
            "register"
          ]
        }
      },
      "response": []
    },
    {
      "name": "3. PUT Update Profile",
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{token}}",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Somchai Updated\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{baseUrl}}/auth/profile",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "auth",
            "profile"
          ]
        }
      },
      "response": []
    },
    {
      "name": "4. DELETE Product (Admin)",
      "request": {
        "method": "DELETE",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/products/REPLACE_WITH_PRODUCT_ID",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "products",
            "REPLACE_WITH_PRODUCT_ID"
          ]
        }
      },
      "response": []
    }
  ]
}
