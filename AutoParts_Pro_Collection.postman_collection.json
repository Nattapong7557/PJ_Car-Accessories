{
  "info": {
    "name": "AutoParts Pro Collection",
    "description": "API testing collection for AutoParts Pro (Workshop 3)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1. Authentication (การยืนยันตัวตน)",
      "item": [
        {
          "name": "สมัครสมาชิกใหม่ (Register - Customer)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status Code should be 201\", function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test(\"Response must be in JSON format\", function () {",
                  "    pm.response.to.be.json;",
                  "});",
                  "",
                  "pm.test(\"Check if JWT token exists\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.data.token).to.not.be.undefined;",
                  "    if (jsonData.data.token) {",
                  "        pm.environment.set(\"token\", jsonData.data.token);",
                  "    }",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"กฤษฎา ต้องไกรเลิศ\",\n  \"email\": \"postman@autopartspro.com\",\n  \"password\": \"password1234\",\n  \"phone\": \"0812345678\",\n  \"address\": \"มหาวิทยาลัยกรุงเทพ\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/auth/register",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "register"
              ]
            }
          },
          "response": []
        },
